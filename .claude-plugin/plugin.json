{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "zn-claude-code-toolkit",
  "description": "Personal toolkit plugin with assorted tools for Claude Code",
  "author": {
    "name": "zharinov-nikita",
    "email": "zharinov.nicita@gmail.com"
  },
  "license": "MIT",
  "keywords": ["toolkit", "utilities"],
  "hooks": [
    "./hooks/inject-language.json",
    "./hooks/inject-git-rules.json",
    "./hooks/inject-response-style.json",
