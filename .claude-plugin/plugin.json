{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "zn-claude-code-toolkit",
  "description": "Personal toolkit plugin with assorted tools for Claude Code",
  "version": "1.0.0",
  "author": {
    "name": "zharinov-nikita",
    "email": "zharinov.nicita@gmail.com"
  },
  "license": "MIT",
  "keywords": ["toolkit", "utilities"],
  "userConfig": {
    "response_language": {
      "type": "string",
      "title": "Response language",
      "description": "Language Claude answers in, free-form: Русский, English, Deutsch. Leave empty to keep Claude Code's default behaviour."
    }
  },
  "hooks": [
    "./hooks/inject-language.json",
    "./hooks/inject-git-rules.json",
    "./hooks/inject-response-style.json",
    "./hooks/inject-human-language.json",
    "./hooks/inject-ask-questions.json",
    "./hooks/inject-grounding.json",
    "./hooks/enforce-ask-user-question.json",
    "./hooks/validate-json.json",
    "./hooks/rtk-install.json",
    "./hooks/rtk-proxy.json"
  ]
}
