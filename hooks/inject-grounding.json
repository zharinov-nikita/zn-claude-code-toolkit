{
  "description": "Injects grounding rules (verify APIs/configs via ctx7 and web search instead of memory)",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/hooks/rules/grounding.md\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
