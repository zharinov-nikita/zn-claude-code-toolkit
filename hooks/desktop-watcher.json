{
  "description": "Windows virtual-desktop watcher: moves GUI windows opened by the session to Claude's desktop. SessionStart spawns the watcher; PreToolUse/PostToolUse update the activity marker it relies on",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$OS\" = \"Windows_NT\" ]; then powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/desktop/spawn-desktop-watcher.ps1\"; fi",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$OS\" = \"Windows_NT\" ]; then touch \"${TEMP:-/tmp}/claude-tool-activity.txt\"; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$OS\" = \"Windows_NT\" ]; then touch \"${TEMP:-/tmp}/claude-tool-activity.txt\"; fi",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
