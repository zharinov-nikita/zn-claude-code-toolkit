{
  "description": "Injects the rule that choice questions must go through the AskUserQuestion tool",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/hooks/rules/ask-questions.md\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
